{% liquid
  assign section_class = 'ms-two-col-hero'
  if section.settings.full_width
    assign section_class = section_class | append: ' ms-two-col-hero--full-width'
  endif
%}

<section
  id="ms-two-column-hero-{{ section.id }}"
  class="{{ section_class }}"
  {% if request.visual_preview_mode %}
    data-shopify-visual-preview
  {% endif %}
>
  <div class="ms-two-col-hero__image-col">
    {%- if section.settings.image != blank -%}
      {%- liquid
        assign image_alt = section.settings.image.alt | escape
      -%}
      {{
        section.settings.image
        | image_url: width: 1600
        | image_tag: width: section.settings.image.width, height: section.settings.image.height, widths: '400, 600, 800, 1000, 1200, 1600', sizes: '(min-width: 750px) 50vw, 100vw', alt: image_alt, class: 'ms-two-col-hero__image', loading: 'lazy'
      }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'ms-two-col-hero__image ms-two-col-hero__placeholder' }}
    {%- endif -%}
  </div>

  <div class="ms-two-col-hero__content-col">
    {%- if section.settings.heading != blank -%}
      <h2 class="ms-two-col-hero__heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <div class="ms-two-col-hero__subtext">{{ section.settings.subtext }}</div>
    {%- endif -%}

    {%- if section.settings.cta_label != blank -%}
      <a
        href="{{ section.settings.cta_link | default: '#' }}"
        class="ms-two-col-hero__cta"
      >
        {{- section.settings.cta_label | escape -}}
      </a>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .ms-two-col-hero {
    display: flex;
    flex-direction: column;
    gap: 32px;
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding-block: 48px;
    padding-inline: var(--page-margin, 20px);
    box-sizing: border-box;
  }

  .ms-two-col-hero--full-width {
    max-width: 100%;
    padding-inline: 0;
  }

  @media screen and (min-width: 750px) {
    .ms-two-col-hero {
      flex-direction: row;
      align-items: center;
      gap: 48px;
    }
  }

  .ms-two-col-hero__image-col {
    flex: 1 1 50%;
  }

  .ms-two-col-hero__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: 4px;
  }

  .ms-two-col-hero__placeholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    display: block;
    background-color: #f4f4f4;
    border-radius: 4px;
  }

  .ms-two-col-hero__content-col {
    flex: 1 1 50%;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media screen and (min-width: 750px) {
    .ms-two-col-hero--full-width .ms-two-col-hero__content-col {
      padding-inline: 40px;
    }
  }

  .ms-two-col-hero__heading {
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    font-family: var(--font-heading--family, inherit);
    line-height: 1.2;
    margin: 0;
    color: var(--color-foreground, #121212);
  }

  .ms-two-col-hero__subtext {
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-foreground, #121212);
    opacity: 0.8;
    margin: 0;
  }

  .ms-two-col-hero__subtext p {
    margin: 0;
  }

  .ms-two-col-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 12px 28px;
    background-color: var(--color-foreground, #121212);
    color: var(--color-background, #ffffff);
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    transition: opacity 0.2s ease;
    border: 2px solid transparent;
  }

  .ms-two-col-hero__cta:hover,
  .ms-two-col-hero__cta:focus-visible {
    opacity: 0.75;
  }

  .ms-two-col-hero__cta:focus-visible {
    outline: 2px solid var(--color-foreground, #121212);
    outline-offset: 3px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "MS Two Column Hero",
  "disabled_on": {
    "groups": ["header"]
  },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Welcome to Our Store"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "Discover our latest collection and find the perfect style for you."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "checkbox",
      "id": "full_width",
      "label": "Full width",
      "info": "Stretch section to full viewport width",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "MS Two Column Hero",
      "category": "Hero",
      "settings": {
        "heading": "Welcome to Our Store",
        "subtext": "Discover our latest collection and find the perfect style for you.",
        "cta_label": "Shop Now",
        "cta_link": "shopify://collections/all",
        "full_width": false
      }
    }
  ]
}
{% endschema %}

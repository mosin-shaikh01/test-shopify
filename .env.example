# Shopify Theme Development Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Your Shopify store URL (e.g., https://my-store.myshopify.com)
SHOPIFY_STORE_URL=

# Theme ID from Shopify CLI (visible after running: shopify theme list)
SHOPIFY_THEME_ID=

# Theme access password (from theme admin or Shopify CLI)
# Only needed if using REST API for theme development
SHOPIFY_THEME_PASSWORD=

# Optional: Shopify API credentials for custom integrations
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Optional: Development environment flag
NODE_ENV=development
